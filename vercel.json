{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/",
      "destination": "/api"
    },
    {
      "source": "/login",
      "destination": "/api"
    },
    {
      "source": "/register",
      "destination": "/api"
    },
    {
      "source": "/logout",
      "destination": "/api"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/index.html",
      "destination": "/api"
    },
    {
      "source": "/client/features/(.*)\\.html",
      "destination": "/api"
    }
  ]
}
